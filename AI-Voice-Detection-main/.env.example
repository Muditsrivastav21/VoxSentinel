# API Keys Template - Copy this to .env and fill in your values
# DO NOT commit .env file to git!

# ========== PRIMARY PROVIDER: GROQ (FREE!) ==========
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ========== BACKUP: ASSEMBLYAI (5 hrs/month free) ==========
# Get your key from: https://www.assemblyai.com/app
ASSEMBLYAI_API_KEY=YOUR_ASSEMBLYAI_KEY_HERE

# ========== LEGACY: OPENAI (paid) ==========
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE

# ========== PROVIDER SELECTION ==========
# Speech-to-Text: groq, openai, assemblyai
STT_PROVIDER=groq
# AI Analysis: groq, openai
AI_PROVIDER=groq

# ========== API AUTHENTICATION ==========
API_KEY=sk_track3_YOUR_SECURE_KEY_HERE

# ========== DATABASE (SUPABASE) ==========
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...YOUR_ANON_KEY

# ========== CELERY / REDIS (for async processing) ==========
# For local development: redis://localhost:6379/0
# For production: Use Redis Cloud, Upstash, or render.com Redis
REDIS_URL=redis://localhost:6379/0

# ========== SETTINGS ==========
ENVIRONMENT=development
DEMO_MODE=false
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
